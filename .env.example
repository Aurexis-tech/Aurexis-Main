# Aurexis — environment variable NAMES (no values). Copy to `.env.local` and fill
# in real values locally. `.env` and `.env.local` are git-ignored; NEVER commit
# real keys. See docs/SETUP.md for where to obtain each.

# ── Server-only (used by /api functions; loaded by `vercel dev` from this file
#    at the repo root). NEVER exposed to the browser. ──────────────────────────
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Browser-safe (Phase 1). Vite only exposes vars prefixed with VITE_. Put
#    these in react/.env.local. The anon key is safe in the browser ONLY because
#    Row-Level Security restricts it; the service-role key is NEVER shipped. ────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
